# Local development env. AppAPI injects these in production.
APP_ID=bee_flow_ai
APP_SECRET=dev-secret
APP_VERSION=0.1.0
APP_PORT=9000
NEXTCLOUD_URL=http://localhost:8080

# Customer-configured in prod via `occ app_api:app:setenv bee_flow_ai ...`
BEEFLOW_TENANT_KEY=dev-tenant-key
BEEFLOW_API_BASE_URL=http://localhost:3101
