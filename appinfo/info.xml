<?xml version="1.0"?>
<!--
  Bee Flow Nextcloud connector — ExApp manifest.
  Schema: https://apps.nextcloud.com/schema/apps/info.xsd
  ExApp deployment: https://docs.nextcloud.com/server/latest/developer_manual/exapp_development/tech_details/Deployment.html
-->
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>bee_flow_ai</id>
    <name>Bee Flow</name>
    <summary>AI-native workspace for chat, automation, and your Nextcloud apps</summary>
    <description><![CDATA[
Bee Flow is an AI workspace that connects your Nextcloud account to a hosted assistant capable of working across Files, Mail, Calendar, Deck, Notes, Tasks, Contacts, and Talk.

**What this app does**
- Adds a Bee Flow icon to your Nextcloud top bar.
- Authenticates you against your existing Nextcloud user — no second login.
- Proxies UI requests to the hosted Bee Flow service so you can chat with an AI agent that has access to your Nextcloud data.

**Data flow disclosure**
This connector forwards the following information to the hosted Bee Flow service at beeflow.ai:
- Your Nextcloud account ID, email, and display name (used to identify your Bee Flow tenant).
- The contents of any Nextcloud item you explicitly ask Bee Flow to act on (e.g. an email you ask the assistant to summarise).

The connector does **not** bulk-export file contents, contacts, or calendars. Privacy policy: https://beeflow.ai/privacy

**Requirements**
- A Bee Flow account provisioned by your organisation's Bee Flow administrator.
- A tenant key (issued by Bee Flow) configured in the AppAPI app settings.
        ]]></description>
    <version>0.1.0</version>
    <licence>AGPL-3.0-or-later</licence>
    <author mail="dev@beeflow.ai" homepage="https://beeflow.ai">Bee Flow B.V.</author>
    <namespace>BeeFlow</namespace>
    <documentation>
        <user>https://beeflow.ai/docs/user</user>
        <admin>https://beeflow.ai/docs/admin</admin>
    </documentation>
    <category>integration</category>
    <category>tools</category>
    <website>https://beeflow.ai</website>
    <bugs>https://github.com/Bee-Flow/connector/issues</bugs>
    <repository type="git">https://github.com/Bee-Flow/connector</repository>
    <screenshot>https://github.com/Bee-Flow/connector/raw/main/img/screenshots/01-chat.png</screenshot>
    <screenshot>https://github.com/Bee-Flow/connector/raw/main/img/screenshots/02-routines.png</screenshot>
    <dependencies>
        <nextcloud min-version="31" max-version="34"/>
    </dependencies>
    <!--
        OAuth-style scopes the Bee Flow ExApp uses against this Nextcloud
        instance. Reviewers and admins can audit exactly what data flows
        leave the instance via the connector. Each scope corresponds to a
        Bee Flow agent tool group in `server/integrations/nextcloud*.js`.
    -->
    <scopes>
        <required>
            <value>FILES</value>
            <value>USER_INFO</value>
            <value>GROUPS</value>
        </required>
        <optional>
            <value>NOTIFICATIONS</value>
            <value>CALENDAR</value>
            <value>CONTACTS</value>
            <value>MAIL</value>
            <value>TALK</value>
            <value>DAV</value>
        </optional>
    </scopes>
    <external-app>
        <docker-install>
            <registry>ghcr.io</registry>
            <image>bee-flow/connector</image>
            <image-tag>latest</image-tag>
        </docker-install>
        <environment-variables>
            <variable>
                <name>BEEFLOW_TENANT_KEY</name>
                <display-name>Bee Flow tenant key</display-name>
                <description>HS256 key minted by the Bee Flow admin API. The connector signs JWTs with this key; the SaaS verifies them against the matching tenant.</description>
            </variable>
            <variable>
                <name>BEEFLOW_API_BASE_URL</name>
                <display-name>Bee Flow API base URL</display-name>
                <description>Base URL of the hosted Bee Flow service (default: https://api.beeflow.ai). Override only for staging or on-prem.</description>
                <default>https://api.beeflow.ai</default>
            </variable>
        </environment-variables>
        <!--
            Explicit allow-list of paths the connector serves. The previous
            catch-all `^.*` route was overly permissive — App Store reviewers
            flag it. Anything not matched here is rejected by AppAPI before
            reaching the connector.

            Path map:
              ^img/, ^js/, ^assets/, ^favicon.ico, ^bee-flow-logo, ^index.html,
              ^$                              → static SPA shell
              ^api/                           → SaaS-proxied REST/SSE endpoints
              ^auth/                          → SaaS-proxied auth + OAuth flows
              ^heartbeat, ^init, ^enabled     → AppAPI lifecycle hooks
              ^webhook/nc-events              → NC events_listener forwarder
              ^nc/                            → reverse proxy back to NC (HMAC)
        -->
        <routes>
            <!-- Static SPA shell + assets -->
            <route><url>^$</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^index\.html$</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^favicon\.ico$</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^bee-flow-logo.*</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^BeeFlow-logo.*</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^img\/.*</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^js\/.*</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^assets\/.*</url><verb>GET</verb><access_level>PUBLIC</access_level></route>

            <!-- Application API surface (proxied to SaaS) -->
            <route><url>^api\/.*</url><verb>GET,POST,PUT,DELETE,PATCH</verb><access_level>PUBLIC</access_level></route>
            <route><url>^auth\/.*</url><verb>GET,POST,PUT,DELETE,PATCH</verb><access_level>PUBLIC</access_level></route>

            <!-- AppAPI lifecycle hooks (called by Nextcloud, not the browser) -->
            <route><url>^heartbeat$</url><verb>GET</verb><access_level>PUBLIC</access_level></route>
            <route><url>^init$</url><verb>POST</verb><access_level>ADMIN</access_level></route>
            <route><url>^enabled$</url><verb>PUT</verb><access_level>ADMIN</access_level></route>

            <!-- Webhooks: NC events_listener -> connector -->
            <route><url>^webhook\/.*</url><verb>POST</verb><access_level>ADMIN</access_level></route>

            <!-- HMAC-signed reverse proxy back to NC for SaaS-side calls -->
            <route><url>^nc\/.*</url><verb>GET,POST,PUT,DELETE,PATCH,PROPFIND,REPORT,MKCOL,MOVE,COPY</verb><access_level>PUBLIC</access_level></route>
        </routes>
    </external-app>
</info>
